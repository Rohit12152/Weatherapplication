@model IEnumerable<Weatherapplication.Models.StudentDetails>

<h2>Student List</h2>

<a asp-action="Create" class="btn btn-success">Add Student</a>

<br />
<br />

<table class="table table-bordered">

    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Email</th>
        <th>Mobile</th>
        <th>Course</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.StudentName</td>
            <td>@item.Email</td>
            <td>@item.Mobile</td>
            <td>@item.Course</td>
        </tr>
    }

</table>